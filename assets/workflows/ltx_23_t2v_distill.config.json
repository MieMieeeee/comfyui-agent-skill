    "negative_prompt": {
      "node_title": "CLIP Text Encode (Negative Prompt)",
      "param": "text",
      "value_type": "string"
    },
    "width": {
      "node_title": "EmptyImage",
      "param": "width",
      "value_type": "integer",
      "default": 768
    },
    "height": {
      "node_title": "EmptyImage",
      "param": "height",
      "value_type": "integer",
      "default": 512
    }
  }

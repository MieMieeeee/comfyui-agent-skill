    "landscape_fhd":  { "width": 1920, "height": 1088, "label": "超清 (Full HD)" }
  },
  "default_resolution": "landscape_fast",
  "node_mapping": {
    "prompt": {
      "node_title": "CLIP Text Encode (Positive Prompt)",
      "param": "text",
